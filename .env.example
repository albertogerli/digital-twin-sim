# DigitalTwinSim — Environment Variables
# Copy to .env and fill in your values.

# ── LLM Providers ──────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key          # Optional, only if using OpenAI

# ── Authentication ─────────────────────────────────────────
# Option A: Simple comma-separated keys (all map to "default" tenant)
# DTS_API_KEYS=key1,key2,key3

# Option B: JSON mapping key → tenant_id (takes precedence over DTS_API_KEYS)
# DTS_KEY_MAP={"sk-abc123": "acme-corp", "sk-def456": "beta-client"}

# If neither is set, auth is DISABLED (open access, dev mode).

# ── CORS ───────────────────────────────────────────────────
# Comma-separated allowed origins (default: http://localhost:3000)
# DTS_CORS_ORIGINS=http://localhost:3000,https://app.example.com

# ── Rate Limiting ──────────────────────────────────────────
# DTS_RATE_LIMIT_ENABLED=true               # default: false

# ── Concurrency ────────────────────────────────────────────
# DTS_MAX_CONCURRENT=4                      # default: 4

# ── Environment ────────────────────────────────────────────
# DTS_ENV=production                        # production | development (default)

# ── Database (Sprint 2) ───────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/dts
# REDIS_URL=redis://localhost:6379/0

# ── Observability (Sprint 3) ──────────────────────────────
# DTS_SENTRY_DSN_BACKEND=https://...@sentry.io/...
# DTS_SENTRY_DSN_FRONTEND=https://...@sentry.io/...
