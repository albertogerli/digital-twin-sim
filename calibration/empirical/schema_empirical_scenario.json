{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digitaltwin.sim/schemas/empirical_scenario.json",
  "title": "Empirical Calibration Scenario",
  "description": "Schema for a real-world scenario with ground truth polling data, used to calibrate DynamicsV2 opinion dynamics parameters.",
  "type": "object",
  "required": [
    "id", "domain", "title", "country", "date_start", "date_end",
    "n_rounds", "round_duration_days", "ground_truth_outcome",
    "polling_trajectory", "events", "agents", "covariates"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]{2,4}-\\d{4}-[A-Z0-9_]+$",
      "description": "Unique ID: DOMAIN-YEAR-SLUG (e.g. POL-2016-BREXIT)"
    },
    "domain": {
      "type": "string",
      "enum": [
        "political", "financial", "commercial", "public_health",
        "corporate", "environmental", "technology", "labor",
        "social", "marketing", "sport", "energy", "legal"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "date_start": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "date_end": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "n_rounds": {
      "type": "integer",
      "minimum": 3,
      "maximum": 20
    },
    "round_duration_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365
    },
    "ground_truth_outcome": {
      "type": "object",
      "required": ["pro_pct", "source", "type"],
      "additionalProperties": false,
      "properties": {
        "pro_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Final pro-side percentage among decided voters"
        },
        "source": {
          "type": "string",
          "minLength": 5,
          "description": "URL or bibliographic citation for the ground truth"
        },
        "type": {
          "type": "string",
          "enum": ["referendum", "election", "poll_final", "market_close", "survey", "regulatory_outcome"]
        }
      }
    },
    "polling_trajectory": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["round", "date", "pro_pct", "source"],
        "additionalProperties": false,
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "date": {
            "type": "string",
            "format": "date",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "pro_pct": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 100,
            "description": "Pro-side percentage. null if no data available for this round."
          },
          "against_pct": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 100
          },
          "undecided_pct": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 100
          },
          "sample_size": {
            "type": ["integer", "null"],
            "minimum": 1,
            "description": "Survey sample size. null if not reported."
          },
          "source": {
            "type": "string",
            "minLength": 5
          },
          "pollster": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["round", "description", "shock_magnitude", "shock_direction"],
        "additionalProperties": false,
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "date": {
            "type": "string",
            "format": "date",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "shock_magnitude": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "shock_direction": {
            "type": "number",
            "minimum": -1,
            "maximum": 1,
            "description": "+1 = fully pro, -1 = fully against"
          },
          "source": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "type", "initial_position", "influence"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "type": {
            "type": "string",
            "enum": ["elite", "institutional", "citizen_cluster"]
          },
          "initial_position": {
            "type": "number",
            "minimum": -1,
            "maximum": 1,
            "description": "+1 = fully pro, -1 = fully against"
          },
          "influence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "description": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "covariates": {
      "type": "object",
      "required": ["initial_polarization", "event_volatility"],
      "additionalProperties": false,
      "properties": {
        "initial_polarization": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Standard deviation of initial agent positions"
        },
        "event_volatility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Standard deviation of shock magnitudes across rounds"
        },
        "elite_concentration": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Herfindahl index of elite influence distribution"
        },
        "institutional_trust": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Institutional trust index from survey data"
        },
        "undecided_share": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of undecided at scenario start"
        }
      }
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Free-text notes about data quality, caveats, etc."
    }
  }
}
