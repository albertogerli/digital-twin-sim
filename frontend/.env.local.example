# DigitalTwinSim Frontend — Environment Variables
# Copy to .env.local and adjust as needed.

# Backend API URL (used in rewrites and client-side fetch)
# Default: http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Auth (REQUIRED in production) ──────────────────────────────────
# Single shared password for the login gate. Pick something long; users
# only paste once per 7 days (cookie TTL).
DTS_LOGIN_PASSWORD=change-me

# 32+ char random secret used to HMAC-sign the auth cookie. Generate with:
#   openssl rand -hex 32
# Rotating this value invalidates all existing sessions immediately.
DTS_AUTH_SECRET=replace-with-32-byte-hex-secret

# Sentry DSN (optional, Sprint 3)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
